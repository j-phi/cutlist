{
  "name": "cutlist",
  "version": "0.12.1",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "build:plans": "bun web/scripts/build-plans.ts",
    "predev": "bun run build:plans",
    "dev": "nuxt dev web",
    "prebuild": "bun run build:plans",
    "build": "nuxt build web",
    "prebuild:static": "bun run build:plans",
    "build:static": "nuxt generate web",
    "preview": "nuxt preview web",
    "lint": "prettier --check .",
    "check": "cd web && vue-tsc --noEmit",
    "test": "cd web && vitest run",
    "test:watch": "cd web && vitest",
    "bench": "cd web && vitest run --config vitest.bench.config.ts",
    "postinstall": "nuxt prepare web",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/ri": "^1.2.10",
    "@sentry/nuxt": "^10",
    "@tiptap/extension-file-handler": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extension-youtube": "3.22.4",
    "@tiptap/html": "^3.23.1",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/vue-3": "^3.22.4",
    "browser-image-compression": "^2.0.2",
    "dexie": "^4.4.2",
    "js-yaml": "^4.1.0",
    "panzoom": "^9.4.4",
    "pdf-lib": "^1.17.1",
    "three": "^0.184.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.2",
    "@nuxt/ui": "^3.0.0",
    "@types/bun": "^1.3.12",
    "@types/js-yaml": "^4.0.9",
    "@types/three": "^0.184.0",
    "@vue/test-utils": "^2.4.8",
    "@vueuse/core": "^14.0.0",
    "@vueuse/nuxt": "^14.0.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.9.0",
    "lint-staged": "^15.5.2",
    "nuxt": "^4.0.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5",
    "vue": "^3.4.21",
    "vue-router": "^5.0.0",
    "vue-tsc": "^3.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "overrides": {
    "cross-spawn": "^7.0.6"
  }
}
